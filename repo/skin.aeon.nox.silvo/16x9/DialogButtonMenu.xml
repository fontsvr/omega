<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>90000</defaultcontrol>
	<controls>
		<include>DimBackground</include>
		<control type="group">
			<animation effect="slide" end="0,60" condition="Integer.IsLess(Container(90000).NumItems,5)">Conditional</animation>
			<include>DialogOpenCloseAnimation</include>
			<centerleft>50%</centerleft>
			<centertop>50%</centertop>
			<width>510</width>
			<height>600</height>
			<control type="panel" id="90000">
				<width>510</width>
				<height>600</height>
				<onleft>90000</onleft>
				<onright>90000</onright>
				<onup>90000</onup>
				<ondown>90000</ondown>
				<scrolltime tween="quadratic" easing="out">200</scrolltime>
				<itemlayout width="510" height="60" infoupdate="5000">
					<control type="image">
						<width>510</width>
						<height>60</height>
						<texture>button_nofocus.png</texture>
					</control>
					<control type="label">
						<width>510</width>
						<height>60</height>
						<textcolor>grey2</textcolor>
						<font>font14</font>
						<textoffsetx>35</textoffsetx>
						<label>$INFO[ListItem.Label]</label>
					</control>
					<control type="label">
						<width>510</width>
						<height>60</height>
						<textcolor>grey2</textcolor>
						<font>font14</font>
						<textoffsetx>35</textoffsetx>
						<align>right</align>
						<label>$INFO[ListItem.Label2]</label>
					</control>
				</itemlayout>
				<focusedlayout width="510" height="60" infoupdate="5000">
					<control type="image">
						<width>510</width>
						<height>60</height>
						<texture colordiffuse="$VAR[HighlightBarColor]">button_focus.png</texture>
					</control>
					<control type="label">
						<width>510</width>
						<height>60</height>
						<font>font14</font>
						<textoffsetx>35</textoffsetx>
						<label>$INFO[ListItem.Label]</label>
					</control>
					<control type="label">
						<width>510</width>
						<height>60</height>
						<font>font14</font>
						<textoffsetx>35</textoffsetx>
						<align>right</align>
						<label>$INFO[ListItem.Label2]</label>
					</control>
				</focusedlayout>
				<content>
					<include>skinshortcuts-group-buttonmenu</include>
					<item>
		                <label>13012</label>
						<onclick>Dialog.Close(all,true)</onclick>
		                <onclick>Quit()</onclick>
					</item>
					<item>
					 <label></label>
		             <label>20183</label>
		             <onclick>ReloadSkin()</onclick>
					</item>
					<item>
		                <label>Ajustes Iniciales [COLOR hotpink]RikTeam[/COLOR]</label>
						<onclick>Dialog.Close(all,true)</onclick>
						<onclick>ActivateWindow(5200)</onclick>
		                <onclick>Skin.SetBool(FirstPagina,false)</onclick>
		                <onclick>Skin.SetBool(FirstRunSetup,false)</onclick>
		                <onclick>Skin.SetBool(3RunSetup,false)</onclick>					
					</item>
					<item>
		                <label>20077</label>
						<onclick>Dialog.Close(all,true)</onclick>
		                <onclick>ActivateWindow(skinsettings)</onclick>
					</item>
					<item>
						<label>5</label>
						<onclick>Dialog.Close(all,true)</onclick>
						<onclick>ActivateWindow(settings)</onclick>
					</item>
					<item>
		                <label>1036</label>
						<onclick>Dialog.Close(all,true)</onclick>
		                <onclick>ActivateWindow(favouritesbrowser)</onclick>
					</item>
					<item>
		               <label>[COLOR pink]Necesario instalar [COLOR goldenrod]Script RikTeam[/COLOR]!</label>
		               <onclick>Dialog.Close(all,true)</onclick>
					   <onclick condition="!System.HasAddon(plugin://script.rikteam)">InstallAddon(script.rikteam)</onclick>
		               <visible>!System.HasAddon(script.rikteam)</visible>
					</item>
					<item>
		               <label>Restablecer ajuste [COLOR hotpink]$INFO[System.AddonTitle(skin.aeon.nox.silvo)] $INFO[System.AddonVersion(skin.aeon.nox.silvo),(,)][/COLOR]</label>
                       <onclick>Dialog.Close(all,true)</onclick>
		               <onclick>ReplaceWindow(Programs,"plugin://script.rikteam/?mode=install&amp;action=build&amp;name=ajustes+basic+v21",return)</onclick>
		               <onclick>Skin.SetBool(preguntado_ajustes,true)</onclick>
					</item>
					<item>
		               <label>Cierre rápido Kodi</label>
                       <onclick>Dialog.Close(all,true)</onclick>
		               <onclick>ActivateWindow(Programs,"plugin://script.rikteam/?mode=forceclose",return)</onclick>
		               <visible>System.HasAddon(script.rikteam)</visible>
					</item>
				</content>
			</control>
		</control>
	</controls>
</window>